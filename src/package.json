{
  "name": "ai-generated-project",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start --workspace backend\" \"npm run start --workspace frontend\"",
    "lint": "eslint \"frontend/src/**\" \"backend/src/**\"",
    "start:backend": "npm --workspace backend run dev",
    "start:frontend": "npm --workspace frontend start"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "eslint": "^8.40.0"
  }
}
